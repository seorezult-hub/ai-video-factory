# ─── Supabase ────────────────────────────────────────────────────────────────
# Get from: https://app.supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Google Gemini ────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/apikey
# Free: Flash-Lite 1000 req/day, Flash 250 req/day
GEMINI_API_KEY=AIzaSy...

# ─── HuggingFace (Flux schnell images) ───────────────────────────────────────
# Get from: https://huggingface.co/settings/tokens
# Free: ~300 req/hour
HUGGINGFACE_TOKEN=hf_...

# ─── fal.ai (Kling video generation fallback) ─────────────────────────────────
# Get from: https://fal.ai/dashboard/keys
# $0.029/sec (~$5-15/month for fallback)
FAL_API_KEY=...

# ─── n8n Webhooks ─────────────────────────────────────────────────────────────
# Your n8n instance webhook URLs (configure after importing workflows)
N8N_ASSEMBLE_WEBHOOK_URL=http://YOUR_N8N_HOST:5678/webhook/assemble-video
N8N_MUSIC_WEBHOOK_URL=http://YOUR_N8N_HOST:5678/webhook/generate-music

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
