# ─── AI Models (LLM) ──────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=                   # Google Gemini — script/frames/quality gate

# Get from: https://console.groq.com → API Keys
GROQ_API_KEY=                     # Groq — judge/fallback LLM (14400 req/day free)

# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=               # OpenRouter — Claude escalation for script

# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=                # Direct Claude API (fallback)

# ─── Video Generation ─────────────────────────────────────────────────────────
# Get from: Atlas Cloud dashboard
ATLAS_CLOUD_API_KEY=              # Atlas Cloud — Seedance 2.0 (основной, $0.022/сек)

# Get from: https://fal.ai/dashboard/keys
FAL_API_KEY=                      # fal.ai — Seedance 1.5/Recraft/upscaler/rembg (fallback)

# Get from: https://piapi.ai/
PIAPI_KEY=                        # piapi.ai — Midjourney v7

# ─── Voice & Audio ────────────────────────────────────────────────────────────
# Get from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=               # ElevenLabs — voiceover TTS (10k символов/мес free)

# ─── Image Generation (frames) ───────────────────────────────────────────────
# Get from: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=                # HuggingFace — Flux schnell frames (~300 req/hour free)

# ─── Storage ──────────────────────────────────────────────────────────────────
# Get from: https://app.supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=         # https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=    # anon key (public, safe for client)
SUPABASE_SERVICE_ROLE_KEY=        # service_role key (secret, server-only!)

# ─── Website Analysis ─────────────────────────────────────────────────────────
# Get from: https://firecrawl.dev
FIRECRAWL_API_KEY=                # firecrawl.dev — опционально, без него базовый парсинг

# ─── n8n Webhooks ─────────────────────────────────────────────────────────────
N8N_ASSEMBLE_WEBHOOK_URL=         # http://n8n:5678/webhook/assemble-video

# ─── App Config ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=              # https://your-domain.com (для CORS в middleware)
INTERNAL_API_SECRET=              # случайная строка для internal server-to-server auth

# ─── Monitoring (опционально) ─────────────────────────────────────────────────
SENTRY_DSN=                       # Sentry DSN для error tracking
