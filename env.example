# ─── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Шифрование ───────────────────────────────────────────────────────────────
# openssl rand -hex 32
ENCRYPTION_KEY=

# ─── Видеогенерация ────────────────────────────────────────────────────────────
ATLAS_CLOUD_API_KEY=
FAL_API_KEY=fal-...
RUNWAY_API_KEY=
OPENAI_API_KEY=sk-...
GOOGLE_AI_KEY=AIza...

# ─── Кадры ────────────────────────────────────────────────────────────────────
PIAPI_KEY=
HUGGINGFACE_TOKEN=hf_...

# ─── AI / LLM ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIza...
GROQ_API_KEY=gsk_...
OPENROUTER_API_KEY=sk-or-...
FIRECRAWL_API_KEY=fc-...

# ─── Музыка ───────────────────────────────────────────────────────────────────
# piapi.ai — Suno AI music generation (https://piapi.ai)
PIAPI_KEY=

# ─── Озвучка ──────────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=

# ─── Rate Limiting (Redis) ────────────────────────────────────────────────────
# Без этого — in-memory (single instance only)
UPSTASH_REDIS_REST_URL=https://<db>.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# ─── Интеграции ───────────────────────────────────────────────────────────────
N8N_ASSEMBLE_WEBHOOK_URL=https://n8n.example.com/webhook/...
# openssl rand -hex 24 (минимум 16 символов)
INTERNAL_API_SECRET=
# 1 если за reverse proxy (nginx)
TRUST_PROXY=1

# ─── Sentry ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_ORG=
SENTRY_PROJECT=
